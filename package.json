{
  "name": "arch-guard",
  "version": "0.1.0",
  "description": "Statically enforce hexagonal and clean architecture boundaries in TS/JS codebases",
  "type": "module",
  "bin": {
    "arch-guard": "./dist/cli.js"
  },
  "scripts": {
    "build": "bun run scripts/build.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
