    "commander": "^13.1.0",
    "picocolors": "^1.1.1",
    "picomatch": "^4.0.2",
    "ts-morph": "^28.0.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/picomatch": "^4.0.1",
    "bun-types": "^1.2.17",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
